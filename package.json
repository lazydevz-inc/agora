{
  "name": "@lazydevz/agora",
  "version": "0.0.1-alpha.0",
  "description": "An agent harness where ancient philosophers gather to refine intent into reality.",
  "license": "MIT",
  "author": {
    "name": "Sang Rhee",
    "email": "sang@lazydevz.com",
    "url": "https://sangrhee.com"
  },
  "homepage": "https://github.com/lazydevz-inc/agora",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lazydevz-inc/agora.git"
  },
  "bugs": {
    "url": "https://github.com/lazydevz-inc/agora/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agora": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "messages",
    "README.md",
    "LICENSE",
    "CREDITS.md"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/cli/index.js', 0o755)\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests scripts",
    "lint:fix": "biome check --write src tests scripts",
    "lint:locale": "tsx scripts/lint-locale.ts",
    "lint:prompts": "tsx scripts/gen-prompts.ts --check",
    "gen:prompts": "tsx scripts/gen-prompts.ts",
    "format": "biome format --write src tests scripts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm lint:locale && pnpm lint:prompts && pnpm test && pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.22.0"
}
